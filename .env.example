# ── Subscription pricing ─────────────────────────────────────────────────────
# Base price per month in local currency (PHP by default)
# 3-month plan gets 10% off, 6-month gets 20% off — computed automatically
VITE_SUBSCRIPTION_BASE_PRICE=299
VITE_SUBSCRIPTION_CURRENCY=₱

# ── API ───────────────────────────────────────────────────────────────────────
# Base URL for all REST API requests (no trailing slash)
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Set to "true" to bypass the real API and use local mock data
VITE_USE_MOCK=true

# ── Auth provider ─────────────────────────────────────────────────────────────
# Options: "mock" | "rest" | "supabase" | "firebase"
#   mock     — in-memory fake, no network calls (default for development)
#   rest     — calls VITE_API_BASE_URL/auth/* endpoints
#   supabase — uses Supabase Authentication
#   firebase — uses Firebase Authentication SDK
VITE_AUTH_PROVIDER=mock

# ── Supabase (only required when VITE_AUTH_PROVIDER=supabase) ─────────────────
VITE_SUPABASE_URL=https://dgnpiexszwsjrqfeefmd.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_-TYQ1TxvAMODJsxJ-75k9g_vderW1et

# ── Firebase ──────────────────────────────────────────────────────────────────
# Required only when VITE_AUTH_PROVIDER=firebase
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Supabase Edge Functions (set via `supabase secrets set`, not .env) ───────
# SUPABASE_SERVICE_ROLE_KEY is injected automatically by Supabase into Edge Functions.
# Never put it in .env or commit it. Listed here as a reminder of the dependency.
# SUPABASE_SERVICE_ROLE_KEY=   ← managed by Supabase, do not set manually

# ── Storage (SERVER-SIDE ONLY — never prefix with VITE_) ──────────────────────
# These variables are intentionally NOT prefixed with VITE_ so Vite never
# bundles them into the client. Use them only in server/edge function code.

# Active storage backend: "r2" (Cloudflare) | "s3" (AWS)
STORAGE_BACKEND=r2

# ── Cloudflare R2 (when STORAGE_BACKEND=r2) ───────────────────────────────────
# Found in: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional: public bucket URL (e.g. https://pub-xxx.r2.dev or custom domain)
# Leave empty to use signed URLs for all file access.
R2_PUBLIC_URL=

# ── AWS S3 (when STORAGE_BACKEND=s3) ─────────────────────────────────────────
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
# Optional: CloudFront or other CDN URL in front of the bucket
S3_PUBLIC_URL=
